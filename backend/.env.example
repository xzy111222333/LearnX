# Server Configuration
PORT=3001
NODE_ENV=development

# MySQL Configuration
# When using docker-compose, set DB_HOST to the database service name (e.g., 'db')
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=material_management

# JWT Configuration
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# AI Configuration
# Option 1: DeepSeek cloud API (recommended)
AI_PROVIDER=deepseek
AI_API_KEY=your_deepseek_api_key_here
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# Option 2: Ollama local model (no API key required)
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=qwen3:8b

