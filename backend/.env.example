# Server Configuration
PORT=3001
NODE_ENV=development

# MySQL Configuration
# When using docker-compose, set DB_HOST to the database service name (e.g., 'db')
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=material_management

# JWT Configuration
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
